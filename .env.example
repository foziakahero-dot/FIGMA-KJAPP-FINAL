# KJAPP — frontend env (Vite). ONLY anon/publishable keys here.
# Secret keys live in Supabase Edge Function env (set via Supabase Dashboard or `supabase secrets set`).

# Supabase (public)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Stripe (publishable key only; secret key is in edge env)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Google Maps JS API key (for client-side map rendering — restrict by referrer in Google Console)
VITE_GOOGLE_MAPS_API_KEY=AIza...

# --- DO NOT COMMIT BELOW. SET AS SUPABASE EDGE FUNCTION SECRETS. ---
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# OPENAI_API_KEY=sk-...
# GOOGLE_MAPS_API_KEY=AIza...  (server-side, separate from VITE_ key, restrict by IP)
# SUPABASE_SERVICE_ROLE_KEY=eyJ...  (auto-injected in edge runtime)
